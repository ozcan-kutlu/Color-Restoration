CR_APP_NAME="color-restoration"
CR_API_V1_PREFIX="/api/v1"
CR_ENVIRONMENT="dev"
CR_MODEL_PATH="models/colorization.keras"
# Docker / Render: imajda model yoksa buradan indirilir.
# - Doğrudan .keras (veya .h5) HTTPS URL, veya
# - GitHub Release .zip asset (içinde colorization.keras); URL .zip ile bitmeli.
# URL zip değil ama içerik zip ise: CR_MODEL_DOWNLOAD_AS_ZIP=1
# CR_MODEL_DOWNLOAD_URL=

CR_INFERENCE_IMAGE_SIZE=256

# İsteğe bağlı: tarayıcıdan doğrudan API (farklı origin). Virgülle ayırın.
# Örnek Vercel: https://proje-adin.vercel.app
# CR_CORS_ORIGINS="https://proje-adin.vercel.app"

# Render vb. platformlar PORT verir; Dockerfile varsayılanı 8000 (yerel / compose).
